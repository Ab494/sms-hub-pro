# Production Environment
# Real users, real money, real SMS — never break this
# Actual values live in Render dashboard ONLY — never here

NODE_ENV=production
PORT=10000
FRONTEND_URL=https://254convexcomltd.africa

# MongoDB Atlas production cluster
MONGODB_URI=MANAGED_IN_RENDER_DASHBOARD

# JWT — must be long random string
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=MANAGED_IN_RENDER_DASHBOARD
JWT_EXPIRES_IN=7d

# BlessedTexts — live credentials
BLESSEDTEXTS_API_KEY=MANAGED_IN_RENDER_DASHBOARD
BLESSEDTEXTS_SENDER=FERRITE
DEFAULT_SENDER_ID=FERRITE

SMS_COST_PER_UNIT=0.46

ADMIN_EMAIL=MANAGED_IN_RENDER_DASHBOARD
ADMIN_PASSWORD=MANAGED_IN_RENDER_DASHBOARD
