# Development Environment
# Used on your local machine with Docker

NODE_ENV=development
PORT=10000
FRONTEND_URL=http://localhost:8082

# MongoDB Atlas (same cluster, different database name)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/smshubpro_dev

# JWT — any string for local dev
JWT_SECRET=dev-secret-not-for-production
JWT_EXPIRES_IN=7d

# BlessedTexts SMS Gateway
BLESSEDTEXTS_API_KEY=your-api-key
BLESSEDTEXTS_SENDER=SMSHUB
DEFAULT_SENDER_ID=SMSHUB

# SMS pricing
SMS_COST_PER_UNIT=0.46

# Admin account
ADMIN_EMAIL=admin@smshubpro.com
ADMIN_PASSWORD=admin123
