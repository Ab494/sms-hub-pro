# Staging Environment
# Real server, test data — safe to break

NODE_ENV=staging
PORT=10000
FRONTEND_URL=https://staging.254convexcomltd.africa

# MongoDB Atlas (separate staging database)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/smshubpro_staging

# JWT — use real random string on staging
JWT_SECRET=CHANGE_ME_RANDOM_STRING
JWT_EXPIRES_IN=7d

# BlessedTexts — use test credentials on staging
BLESSEDTEXTS_API_KEY=CHANGE_ME
BLESSEDTEXTS_SENDER=SMSHUB
DEFAULT_SENDER_ID=SMSHUB

SMS_COST_PER_UNIT=0.46

ADMIN_EMAIL=admin@smshubpro.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
